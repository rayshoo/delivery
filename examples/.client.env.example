# DELIVERY_SERVER_ADDR=0.0.0.0
# DELIVERY_SERVER_PORT=12010
# DELIVERY_SERVER_ROOT_CERT=<server root cert path when use tls>
# DELIVERY_LOG_LEVEL=Info
# DELIVERY_COMMIT_USER_NAME=Administrator
# DELIVERY_COMMIT_USER_EMAIL=admin@example.com
# DELIVERY_COMMIT_MESSAGE=<commit message>
# DELIVERY_COMMIT_PROJECT=<commit project path>
# DELIVERY_COMMIT_BRANCH=<commit branch>
# DELIVERY_COMMIT_SHORT_SHA=<commit short sha>
# DELIVERY_SPECS='[{"url":"<git url>","kustomize":[{"branch":"<branch>","paths":[{"path":"<kustomize file directory>","images":[{"name":"<image name>","newName":"<new image name>","newTag":"<new image tag>"}],"updates":[{"key":"<yaml key>","value":"<yaml value>"}]}]}]}]'
# DELIVERY_SPECS_FILE=<yaml|json file path>
# DELIVERY_TIMEOUT=<second,numeric>
# DELIVERY_NOTIFY_SPEC='{"notify":{"slack":[{"url":"https://slack.com/api/chat.postMessage","token":"${SLACK_TOKEN}","data":"channel: ${DELIVERY_NOTIFY_CHANNEL}\nblocks:\n- type: header\n  text:\n    type: plain_text\n    text: ':typingcat: GitLab CI Completed'\n- type: section\n  fields:\n  - type: mrkdwn\n    text: Start to Sync <${CI_SERVER_URL}/${APP_PATH}|ArgoCD App>\nattachments:\n- color: '#2eb886'\n  blocks:\n  - type: section\n    fields:\n    - type: mrkdwn\n      text: |\n        *Pipeline*\n        <${CI_PIPELINE_URL}|ID #${CI_PIPELINE_ID} | IID #${CI_PIPELINE_IID}>\n    - type: mrkdwn\n      text: |\n        *Project*\n        <${CI_PROJECT_URL}|${CI_PROJECT_PATH}>\n    - type: mrkdwn\n      text: '*Branch* <${CI_PROJECT_URL}/-/tree/${CI_COMMIT_BRANCH}|${CI_COMMIT_BRANCH}>'\n    - type: mrkdwn\n      text: '*Commit* <${CI_PROJECT_URL}/-/commit/${CI_COMMIT_SHA}|${CI_COMMIT_SHORT_SHA}>'\n    - type: mrkdwn\n      text: '*User* <${CI_SERVER_URL}/${GITLAB_USER_LOGIN}|${GITLAB_USER_NAME}>'\n    accessory:\n      type: image\n      image_url: ${IMAGE_URL}\n      alt_text: ${GITLAB_USER_NAME}\n  - type: divider\n  - type: section\n    text:\n      type: mrkdwn\n      text: |\n        *Commit Message*\n        ${CI_COMMIT_TITLE}\n        ```${CI_COMMIT_DESCRIPTION}```"}]}}'
# DELIVERY_NOTIFY_SPEC_FILE=<yaml|json file path>
# DELIVERY_NOTIFY_TIMEOUT=<second,numeric>